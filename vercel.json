{
  "version": 2,
  "functions": {
    "api/meme.js": {
      "runtime": "edge"
    },
    "api/index.js": {
      "runtime": "edge"
    }
  },
  "routes": [
    {
      "src": "/api/meme",
      "dest": "/api/meme.js"
    },
    {
      "src": "/",
      "dest": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
